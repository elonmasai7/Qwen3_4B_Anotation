CONTEXTFORGE_ENV=local
CONTEXTFORGE_DATA_DIR=data

DATABASE_URL=sqlite:///./contextforge.db
USE_POSTGRES=false

QWEN_MODEL_NAME=Qwen/Qwen3-4B
USE_VLLM=false
DEVICE=auto

RETRIEVAL_TOP_K=6
RETRIEVAL_BACKEND=faiss
FAISS_INDEX_DIR=data/processed/faiss
PGVECTOR_TABLE=example_embeddings
MAX_CHUNK_TOKENS=2048
CHUNK_OVERLAP_TOKENS=256

QUEUE_BACKEND=sqlite
QUEUE_POLL_INTERVAL_S=0.2

TEMPERATURE=0.1
TOP_P=0.9
MAX_NEW_TOKENS=1024
